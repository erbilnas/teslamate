# TeslaMate - Oracle Cloud / Public Deployment
# Copy this file to .env and fill in your values before running docker compose up

# Generate a secure key: openssl rand -base64 32
TM_ENCRYPTION_KEY=

# Database credentials (use strong passwords)
TM_DB_USER=teslamate
TM_DB_PASS=
TM_DB_NAME=teslamate

# Grafana admin credentials
GRAFANA_USER=admin
GRAFANA_PW=

# Your domain - must point to your server's public IP (e.g. teslamate.yourdomain.com)
FQDN_TM=teslamate.example.com

# Timezone
TM_TZ=Europe/Berlin

# Email for Let's Encrypt certificate notifications
LETSENCRYPT_EMAIL=yourperson@example.com
